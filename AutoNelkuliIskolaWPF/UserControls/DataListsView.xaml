<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.DataListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="Black" Padding="15" CornerRadius="8">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <ItemsControl ItemsSource="{Binding Students}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5" Padding="10" Background="#F5F5F5" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="16"/>
                                <TextBlock Text="{Binding Age}" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>

    </Border>
</UserControl>