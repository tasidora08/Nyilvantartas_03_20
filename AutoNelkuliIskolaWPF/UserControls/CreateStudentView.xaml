<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.CreateStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White" Padding="20" CornerRadius="8">
        <StackPanel>

            <TextBlock Text="Új tanuló létrehozása"
                       FontSize="22"
                       Margin="0,0,0,15"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Label Grid.Column="0" Grid.Row="0">NÉV:</Label>
                <TextBox x:Name="nameTextBox" Grid.Column="1" Grid.Row="0" Margin="0,5" HorizontalAlignment="Right" MinWidth="200"/>

                <Label Grid.Column="0" Grid.Row="1">SZÜLETÉSI DÁTUM:</Label>
                <DatePicker x:Name="bornDate" Grid.Column="1" Grid.Row="1" Margin="0,5" HorizontalAlignment="Right" MinWidth="200"/>

                <Label Grid.Column="0" Grid.Row="2">ANYJA NEVE:</Label>
                <TextBox x:Name="motherNameTextBox" Grid.Column="1" Grid.Row="2" Margin="0,5" HorizontalAlignment="Right" MinWidth="200"/>

                <Label Grid.Column="0" Grid.Row="3">KRESZ VIZSGA:</Label>
                <RadioButton x:Name="TrafficPoliceExamRadioBtn" Grid.Column="1" Grid.Row="3" Margin="0,5" HorizontalAlignment="Right" MinWidth="200"/>

                <Label Grid.Column="0" Grid.Row="4">EGÉSZSÉGÜGYI VIZSGA:</Label>
                <RadioButton x:Name="MedicalExamRadioBtn" Grid.Column="1" Grid.Row="4" Margin="0,5" HorizontalAlignment="Right" MinWidth="200"/>
            </Grid>
            

            <Button Margin="0,10,0,0" Height="35" Click="CreateStudentButton_Click">Mentés</Button>
            <Label x:Name="feedbackText"></Label>

        </StackPanel>
    </Border>

</UserControl>