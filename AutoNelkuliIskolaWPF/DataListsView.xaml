<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.DataListsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF2F7"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#EDF2F7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <!-- Header -->
            <TextBlock Text="Adatok áttekintése" FontSize="22" FontWeight="Bold"
                       Foreground="#2D3748" Margin="0,0,0,20"/>

            <!-- Stat Cards -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock x:Name="TxtInstructorCount" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#3498DB" Margin="0,4,0,2"/>
                        <TextBlock Text="Oktató" Foreground="#718096" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock x:Name="TxtLearnerCount" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#27AE60" Margin="0,4,0,2"/>
                        <TextBlock Text="Tanuló" Foreground="#718096" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock x:Name="TxtMedicalCount" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#E67E22" Margin="0,4,0,2"/>
                        <TextBlock Text="Egészségügyi vizsgával" Foreground="#718096" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="0">
                    <StackPanel>
                        <TextBlock x:Name="TxtKreszCount" Text="0" FontSize="28"
                                   FontWeight="Bold" Foreground="#9B59B6" Margin="0,4,0,2"/>
                        <TextBlock Text="KRESZ vizsgával" Foreground="#718096" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Instructor + Students Section -->
            <Border Background="White" CornerRadius="10" Padding="0,0,0,0" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Border Padding="16,14" BorderBrush="#EDF2F7" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Oktatók és tanulóik" FontSize="15"
                                       FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                            <!-- Filter -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Szűrés oktató szerint:" VerticalAlignment="Center"
                                           Foreground="#718096" FontSize="12" Margin="0,0,8,0"/>
                                <ComboBox x:Name="CmbInstructorFilter" Width="160" FontSize="12"
                                          SelectionChanged="CmbInstructorFilter_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="DgStudents" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tanuló neve" Binding="{Binding LearnerName}" Width="160"/>
                            <DataGridTextColumn Header="Születési dátum" Binding="{Binding BornDate}" Width="130"/>
                            <DataGridTextColumn Header="Kor" Binding="{Binding Age}" Width="60"/>
                            <DataGridTextColumn Header="Anyja neve" Binding="{Binding MotherName}" Width="160"/>
                            <DataGridTextColumn Header="Óra" Binding="{Binding DrivedHours}" Width="60"/>
                            <DataGridTemplateColumn Header="Egészségügyi" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasMedicalExam, Converter={StaticResource BoolToCheck}}"
                                                   HorizontalAlignment="Center" FontSize="16"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="KRESZ" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HasTrafficPoliceExam, Converter={StaticResource BoolToCheck}}"
                                                   HorizontalAlignment="Center" FontSize="16"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Oktató" Binding="{Binding InstructorName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Instructors Table -->
            <Border Background="White" CornerRadius="10" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Border Padding="16,14" BorderBrush="#EDF2F7" BorderThickness="0,0,0,1">
                        <TextBlock Text="Oktatók listája" FontSize="15"
                                   FontWeight="SemiBold" Foreground="#2D3748"/>
                    </Border>
                    <DataGrid x:Name="DgInstructors" MaxHeight="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Oktató neve" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Tanulók száma" Binding="{Binding LearnerCount}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
