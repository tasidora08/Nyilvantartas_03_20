<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.CreateStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="520" HorizontalAlignment="Left">

            <TextBlock Text="Tanuló hozzáadása" FontSize="22" FontWeight="Bold"
                       Foreground="#2D3748" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="10" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>

                    <!-- Name -->
                    <TextBlock Text="Tanuló neve *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource FormBox}" Margin="0,0,0,16"/>

                    <!-- Born date -->
                    <TextBlock Text="Születési dátum *" Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="DpBornDate" FontSize="13" Margin="0,0,0,16"
                                SelectedDateFormat="Short"/>

                    <!-- Mother name -->
                    <TextBlock Text="Anyja neve *" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtMotherName" Style="{StaticResource FormBox}" Margin="0,0,0,16"/>
                    <!-- Hours -->
                    <TextBlock Text="Vezetett órák" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtHours" ToolTip="A módosításhoz KRESZ vizsga megléte szükséges!" IsEnabled="False" Style="{StaticResource FormBox}" Text="0" Margin="0,0,0,16"/>
                    <TextBlock x:Name="WarningText" Foreground="DarkBlue" Margin="0,0,0,20" Text="A módosításhoz KRESZ vizsga megléte szükséges!"></TextBlock>

                    <!-- Exams -->
                    <TextBlock Text="Vizsgák" Style="{StaticResource FormLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox x:Name="ChkMedical" Content="Egészségügyi vizsga"
                                  FontSize="13" Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <CheckBox x:Name="ChkKresz" Content="KRESZ vizsga"
                                  FontSize="13" VerticalContentAlignment="Center" Click="ChkKresz_Click"/>
                    </StackPanel>

                    <!-- Instructor assignment -->
                    <TextBlock Text="Oktató hozzárendelése (opcionális)" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CmbInstructor" FontSize="13" Padding="8,7"
                              Margin="0,0,0,24"/>

                    <Button Content="Tanuló hozzáadása" Style="{StaticResource PrimaryBtn}"
                            Click="BtnAdd_Click" HorizontalAlignment="Left"/>

                    <Border x:Name="MsgBorder" CornerRadius="6" Padding="12,10" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtMessage" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
