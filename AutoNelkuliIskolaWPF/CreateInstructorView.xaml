<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.CreateInstructorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Form Card -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="24" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Oktató hozzáadása" FontSize="18" FontWeight="Bold"
                               Foreground="#2D3748" Margin="0,0,0,20"/>

                    <TextBlock Text="Oktató neve" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource FormBox}" Margin="0,0,0,20"/>

                    <Button Content="Oktató hozzáadása" Style="{StaticResource PrimaryBtn}"
                            Click="BtnAdd_Click" HorizontalAlignment="Left"/>

                    <Border x:Name="MsgBorder" CornerRadius="6" Padding="12,10" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtMessage" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Instructor List -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Margin="20,0,0,0"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Border Padding="16,14" BorderBrush="#EDF2F7" BorderThickness="0,0,0,1">
                        <TextBlock Text="Jelenlegi oktatók" FontSize="15" FontWeight="SemiBold" Foreground="#2D3748"/>
                    </Border>
                    <ListBox x:Name="LstInstructors" FontSize="13" BorderThickness="0"
                             MaxHeight="400" Padding="8">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Margin" Value="0,2"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
