<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.EditInstructorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E53E3E"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="Oktató szerkesztése" FontSize="22" FontWeight="Bold"
                       Foreground="#2D3748" Margin="0,0,0,20"/>

            <!-- Selector -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Válassz oktatót" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CmbInstructors" FontSize="13" Padding="8,7"
                              SelectionChanged="CmbInstructors_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- Edit panel -->
            <Border x:Name="FormPanel" Background="White" CornerRadius="10" Padding="24"
                    Margin="0,0,0,16" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Oktató adatai" FontSize="15" FontWeight="SemiBold"
                               Foreground="#2D3748" Margin="0,0,0,16"/>

                    <TextBlock Text="Oktató neve" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource FormBox}" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Átnevezés" Style="{StaticResource PrimaryBtn}"
                                Click="BtnRename_Click"/>
                        <Button Content="Oktató törlése" Style="{StaticResource DangerBtn}"
                                Click="BtnDelete_Click"/>
                    </StackPanel>

                    <Border x:Name="MsgBorder" CornerRadius="6" Padding="12,10" Margin="0,14,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtMessage" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Students of instructor -->
            <Border x:Name="StudentsPanel" Background="White" CornerRadius="10"
                    Margin="0,0,0,16" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <Border Padding="16,14" BorderBrush="#EDF2F7" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock x:Name="TxtStudentsHeader" Text="Tanulók"
                                       FontSize="15" FontWeight="SemiBold" Foreground="#2D3748"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="DgStudents" AutoGenerateColumns="False" IsReadOnly="True"
                              BorderThickness="0" MaxHeight="250" FontSize="13"
                              RowBackground="White" AlternatingRowBackground="#F8FAFC"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                              HeadersVisibility="Column" CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Név" Binding="{Binding LearnerName}" Width="*"/>
                            <DataGridTextColumn Header="Kor" Binding="{Binding Age}" Width="60"/>
                            <DataGridTextColumn Header="Óra" Binding="{Binding DrivedHours}" Width="60"/>
                            <DataGridTemplateColumn Header="Egészségügyi" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock 
                                                   HorizontalAlignment="Center" FontSize="14"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="KRESZ" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock 
                                                   HorizontalAlignment="Center" FontSize="14"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Move student -->
                    <Border Padding="16,14" BorderBrush="#EDF2F7" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="Tanuló áthelyezése másik oktatóhoz"
                                       Style="{StaticResource FormLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CmbMoveStudent" Grid.Column="0" FontSize="12"
                                          Padding="8,7" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                           FontSize="16" Margin="0,0,8,0" Foreground="#718096"/>
                                <ComboBox x:Name="CmbTargetInstructor" Grid.Column="2" FontSize="12"
                                          Padding="8,7" Margin="0,0,8,0" />
                                <Button Grid.Column="3" Content="Áthelyez" Style="{StaticResource PrimaryBtn}"
                                        Margin="0" Click="BtnMove_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
