<UserControl x:Class="AutoNelkuliIskolaWPF.UserControls.EditStudentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FormBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E53E3E"/>
        </Style>
        <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>
        <Style x:Key="InfoBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#9B59B6"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24" MaxWidth="560" HorizontalAlignment="Left">

            <TextBlock Text="Tanuló szerkesztése" FontSize="22" FontWeight="Bold"
                       Foreground="#2D3748" Margin="0,0,0,20"/>

            <!-- Student selector -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Válassz tanulót" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CmbStudents" FontSize="13" Padding="8,7"
                              SelectionChanged="CmbStudents_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- Edit form -->
            <Border x:Name="FormPanel" Background="White" CornerRadius="10" Padding="24"
                    Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Adatok szerkesztése" FontSize="15" FontWeight="SemiBold"
                               Foreground="#2D3748" Margin="0,0,0,16"/>

                    <TextBlock Text="Tanuló neve" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtName" Style="{StaticResource FormBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="Születési dátum" Style="{StaticResource FormLabel}"/>
                    <DatePicker x:Name="DpBornDate" FontSize="13" Margin="0,0,0,14"/>

                    <TextBlock Text="Anyja neve" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtMotherName" Style="{StaticResource FormBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="Vezetett órák" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtHours" Style="{StaticResource FormBox}" Margin="0,0,0,14"/>

                    <TextBlock Text="Vizsgák" Style="{StaticResource FormLabel}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <CheckBox x:Name="ChkMedical" Content="Egészségügyi vizsga"
                                  FontSize="13" Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <CheckBox x:Name="ChkKresz" Content="KRESZ vizsga"
                                  FontSize="13" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Oktató módosítása" Style="{StaticResource FormLabel}"/>
                    <ComboBox x:Name="CmbInstructor" FontSize="13" Padding="8,7" Margin="0,0,0,20"/>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <Button Content="💾  Adatok frissítése" Style="{StaticResource PrimaryBtn}"
                                Click="BtnUpdate_Click"/>
                        <Button Content="🗑️  Törlés" Style="{StaticResource DangerBtn}"
                                Click="BtnDelete_Click"/>
                        <Button Content="🎓  Vizsgára kész?" Style="{StaticResource InfoBtn}"
                                Click="BtnReady_Click"/>
                    </StackPanel>

                    <Border x:Name="MsgBorder" CornerRadius="6" Padding="12,10" Margin="0,16,0,0"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtMessage" FontSize="13" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
